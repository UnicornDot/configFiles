// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `zed: Open Default Settings` command
// from the command palette
{
  "edit_predictions": {
    "provider": "zed"
  },
  "agent_ui_font_size": 20.0,
  "agent_buffer_font_size": 20.0,
  "icon_theme": "JetBrains New UI Icons (Dark)",
  "outline_panel": {
    "dock": "left",
  },
  "ui_font_size": 24.0,
  "ui_font_family": "Inter",
  "ui_font_weight": 500,
  "buffer_font_size": 20.0,
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_weight": 400,
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "vertical_scroll_margin": 8,
  "extend_comment_on_newline": true,
  "restore_on_startup": "last_workspace",
  "centered_layout": {
    "left_padding": 0.2,
    "right_padding": 0.2,
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte (Blue Blur+)",
    "dark": "Nordfox - blurred",
  },
  "agent": {
    "default_profile": "ask",
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-opus-4-1-thinking",
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
  },
  // 开启本地代理
  // "proxy": "http://127.0.0.1:7890",
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
  },
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "jsx_tag_auto_close": {
    "enabled": true,
  },
  "soft_wrap": "none",
  "format_on_save": "on",
  "file_types": {
    "C++": ["c", "h", "cpp", "hpp"],
    "Markdown": ["*.mdx"],
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/vendor",
    "**/.tmp*",
  ],
  "search": {
    "button": true,
    "include_ignored": false,
    "regex": true,
    "whole_word": false,
    "case_sensitive": false,
    "center_on_match": false,
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font",
    "dock": "bottom",
    "toolbar": {
      "breadcrumbs": false,
    },
    "copy_on_select": true,
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
    },
  },
  "languages": {
    "C++": {
      "formatter": [
        {
          "external": {
            "command": "clang-format",
            "arguments": ["-style=file"],
          },
        },
      ],
    },
    "Go": {
      "format_on_save": "on",
    },
    "TSX": {
      "format_on_save": "on",
    },
    "JavaScript": {
      "format_on_save": "on",
    },
    "TypeScript": {
      "format_on_save": "on",
    },
    "Rust": {
      "tab_size": 4,
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "checkOnSave": true,
      },
    },
    "eslint": {
      "settings": {
        "codeActionOnSave": {
          "rules": ["import/order"],
        },
      },
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "project_panel": {
    "button": true,
    "dock": "left",
    "git_status": true,
  },
}
